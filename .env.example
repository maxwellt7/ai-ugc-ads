# =============================================================================
# ugc-ad-director environment template
# Copy to .env (which is gitignored) and fill in real values.
# Defaults are tuned to preserve current Manus/Forge behavior.
# =============================================================================

# --- Core runtime ----------------------------------------------------------
NODE_ENV=development
PORT=3000
VITE_APP_ID=

# JWT secret used for session cookie signing (legacy Manus cookie path).
JWT_SECRET=

# --- Database --------------------------------------------------------------
# Required for the server and drizzle CLI. Example MySQL connection string.
DATABASE_URL=mysql://user:password@127.0.0.1:3306/ugc_ad_director
DATABASE_PROVIDER=mysql

# --- Auth ------------------------------------------------------------------
# Provider selector: "manus" (current default) or "custom" (JWT/JWKS).
AUTH_PROVIDER=manus

# Manus / OAuth (legacy path — required while AUTH_PROVIDER=manus)
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Custom JWT provider (used when AUTH_PROVIDER=custom)
# Pick exactly one verification mode: JWKS (preferred) or shared secret.
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWKS_URL=
AUTH_JWT_SECRET=

# --- LLM -------------------------------------------------------------------
# Provider selector: "manus" (default), "openai", "anthropic", "gemini".
LLM_PROVIDER=manus
# Optional shadow provider — invokes a second provider in parallel for diffing.
LLM_SHADOW_PROVIDER=

# Manus / Forge (legacy path — required while LLM_PROVIDER=manus or STORAGE_PROVIDER=forge)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
LLM_MODEL_MANUS=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL_OPENAI=gpt-4.1-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL_ANTHROPIC=claude-3-5-sonnet-latest

# Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL_GEMINI=gemini-2.5-flash

# --- Storage ---------------------------------------------------------------
# Provider selector: "forge" (default, uses Manus Forge presigned URLs),
# "s3" (AWS S3), or "r2" (Cloudflare R2 — S3-compatible).
STORAGE_PROVIDER=forge

# S3 / R2 config (required when STORAGE_PROVIDER=s3 or r2)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Cutover safety flags — set "true" during phased rollout, then disable.
STORAGE_DUAL_WRITE=false
STORAGE_DUAL_READ_VERIFY=false
# Copy provider-hosted media (Shotstack/WaveSpeed outputs) into our bucket
# when the job completes, so URLs remain valid after vendor TTLs expire.
STORAGE_DURABLE_MEDIA_COPY=false

# --- Webhooks --------------------------------------------------------------
# Shared HMAC secret for vendor → our webhook callbacks (WaveSpeed, Shotstack).
# Configure the same value in each vendor dashboard.
WEBHOOKS_SHARED_SECRET=

# --- Vendor API keys -------------------------------------------------------
WAVESPEED_API_KEY=
SHOTSTACK_API_KEY=
